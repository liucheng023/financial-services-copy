# Copy to `.env` (never commit) and fill in real values.
#
# Two Supabase URLs are intentionally separate:
#   SUPABASE_URL         HTTPS PostgREST/Auth/Storage entrypoint used by the
#                        supabase-py client. Looks like https://<ref>.supabase.co
#   SUPABASE_DB_URL      Postgres connection string (postgresql://...) used by
#                        psql for migrations and by anything that needs direct
#                        SQL access. Phase 1 FastAPI runtime does NOT read this;
#                        only migration tooling does.

# Required for the FastAPI runtime (uvicorn app.main:app):
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
INTERNAL_ADMIN_TOKEN=

# Importer-only required — read directly by app/importers/_cli_common.py.
# Needed when running ``python -m app.importers.import_*`` to ingest upstream
# agents/skills/MCPs from the anthropics/financial-services ``plugins/`` tree.
# The FastAPI runtime does NOT read this; leave unset for runtime-only smoke.
# UPSTREAM_PLUGINS_PATH=

# Migration-only required — Postgres connection string used by psql /
# supabase-cli for schema migrations. The FastAPI runtime does NOT read it.
# SUPABASE_DB_URL=

# Legacy optional — Phase 1 now uses the ``model_configs`` Supabase table
# (managed through ``POST /api/model-configs``) as the LLM endpoint source
# of truth. These env vars are preserved for backward-compatible local
# setups and out-of-lifecycle scripts; the FastAPI runtime does not read them.
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=

# Optional:
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
